PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/youtube_clone?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_secret

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@yourtube.app

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+10000000000

TRANSLATE_API_URL=https://your-translation-service.example/translate

OTP_DEBUG_MODE=false
NODE_ENV=production
